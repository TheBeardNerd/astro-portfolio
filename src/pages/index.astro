---
import Layout from '../layouts/Layout.astro'
import Skills from '../components/Skills.astro'
import ContactForm from '../components/ContactForm.astro'
import CareerTimeline from '../components/CareerTimeline.astro'
import CornerTicks from '../components/blueprint/CornerTicks.astro'
import HeroDraftingCanvas from '../components/HeroDraftingCanvas.astro'
---

<Layout>
  <!-- Hero -->
  <section
    class="relative flex flex-col min-h-svh px-6 md:px-12 pb-20 overflow-hidden"
    aria-label="Introduction"
  >
    <HeroDraftingCanvas />
    <!-- Vertically centered content wrapper -->
    <div
      class="relative z-10 w-full max-w-screen-xl mx-auto flex flex-col flex-1 justify-center gap-4 md:gap-5 py-8"
    >
      <!-- TRAVIS wordmark -->
      <div data-animate="fade" data-animate-delay="200">
        <h1
          class="font-display text-bp-text select-none text-center md:text-left"
          style="line-height: 0.88;"
        >
          <span class="block text-[22vw] md:text-[14vw]">TRAVIS</span>
          <span class="block text-[8.5vw] md:text-[5.5vw]"
            >WINDSOR-CUMMINGS</span
          >
        </h1>
      </div>

      <!-- Full-width datum line — separates title block from data block -->
      <div
        class="flex items-center gap-3"
        aria-hidden="true"
        data-animate="fade"
        data-animate-delay="700"
      >
        <span class="border-top-amber-dashed flex-1 block h-px"></span>
        <span class="font-mono text-xs text-bp-amber tracking-widest shrink-0"
          >[ v2.0 ]</span
        >
      </div>

      <!-- Subtitle -->
      <p
        class="font-mono text-[11px] tracking-widest uppercase text-bp-steel text-center md:text-left flex flex-col items-center md:block"
        data-animate="fade"
        data-animate-delay="500"
      >
        <span class="md:inline">SOFTWARE ENGINEER</span>
        <span
          class="md:inline leading-none md:leading-normal"
          aria-hidden="true"
        >
          —
        </span>
        <span class="md:inline">MEMPHIS GRIZZLIES</span>
        <span
          class="md:inline leading-none md:leading-normal"
          aria-hidden="true"
        >
          —
        </span>
        <span class="md:inline">MEMPHIS, TN</span>
      </p>

      <!-- Tagline -->
      <p
        class="font-display text-2xl md:text-4xl text-bp-text tracking-wider uppercase text-center md:text-left"
        data-animate="fade"
        data-animate-delay="800"
      >
        <span class="block md:inline">Field tested.</span>
        <span class="block md:inline"> Built differently.</span>
      </p>

      <!-- Data block: text/action left, headshot right -->
      <!-- DOM order: CTA before headshot so CTA is visible above fold on mobile -->
      <div
        class="flex flex-col-reverse md:flex-row md:items-start md:justify-between gap-8 md:gap-16 mt-4 md:mt-6"
      >
        <!-- Left column: primary + secondary CTA -->
        <div class="flex flex-col items-center md:items-start gap-5">
          <!-- Primary CTA -->
          <a
            href="/resume"
            class="btn-transmit inline-block px-8 py-3 font-display text-xl tracking-widest text-bp-bg border-2 border-bp-amber bg-bp-amber hover:text-bp-bg transition-colors duration-300"
            data-animate="fade"
            data-animate-delay="1000"
          >
            VIEW RECORD →
          </a>

          <!-- Secondary CTA -->
          <a
            href="/#contact"
            class="font-mono text-sm tracking-widest text-bp-amber hover:text-bp-text transition-colors duration-200 mt-4"
            aria-label="Jump to contact section"
            data-animate="fade"
            data-animate-delay="1200"
          >
            CONTACT →
          </a>
        </div>

        <!-- Right column: coordinates + headshot + subject label -->
        <div
          class="flex flex-col items-center md:items-start gap-3"
          data-animate="fade"
          data-animate-delay="1100"
        >
          <!-- Memphis coordinates — always visible -->
          <p
            class="font-mono text-[11px] tracking-widest text-bp-steel"
            aria-hidden="true"
          >
            35°08'N 90°02'W
          </p>

          <!-- Headshot in blueprint frame -->
          <div class="relative border border-bp-border p-1">
            <CornerTicks size="w-4 h-4" />
            <img
              src="/images/travis_headshot.webp"
              alt="Travis Windsor-Cummings"
              class="block w-44 sm:w-52 md:w-60 lg:w-64"
              width="256"
              height="256"
            />
          </div>

          <!-- Annotation label -->
          <div class="flex items-center gap-2" aria-hidden="true">
            <span class="border-top-amber-solid block h-px w-6"></span>
            <span class="font-mono text-xs text-bp-amber tracking-widest"
              >SUBJECT</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll prompt — pinned to hero bottom -->
    <a
      href="#story"
      class="absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-xs text-bp-steel tracking-widest hover:text-bp-amber transition-colors duration-200 whitespace-nowrap"
      data-animate="fade"
      data-animate-delay="1400"
    >
      ↓ scroll to begin
    </a>
  </section>

  <!-- Story -->
  <section
    id="story"
    class="px-6 py-20 md:px-12 md:py-28 border-t border-bp-border"
  >
    <div class="max-w-screen-xl mx-auto">
      <p
        class="font-mono text-sm text-bp-steel tracking-widest mb-16 max-w-2xl"
        data-animate="fade"
      >
        I didn't arrive at software engineering in a straight line. I took the
        long way around — through restaurants, warehouses, freight yards, and
        five years of showing up every day before I ever wrote a line of code.
        It turns out that was exactly the right path.
      </p>
      <CareerTimeline />
    </div>
  </section>

  <Skills />

  <ContactForm />
</Layout>
