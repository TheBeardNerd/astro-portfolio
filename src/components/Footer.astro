<footer class="border-t border-bp-border px-6 py-10 md:px-12">
  <div class="max-w-screen-xl mx-auto">
    <!-- Bracket line -->
    <div
      class="flex items-center gap-0 w-full font-mono text-xs tracking-widest overflow-hidden"
    >
      <span class="text-bp-amber shrink-0">[&nbsp;&nbsp;</span>
      <span class="text-bp-text uppercase shrink-0">TWC</span>
      <span
        class="mx-3 inline-block h-px bg-bp-border flex-1"
        aria-hidden="true"></span>
      <span class="text-bp-steel shrink-0 uppercase">MEMPHIS, TN</span>
      <span class="mx-3 inline-block h-px bg-bp-border w-8" aria-hidden="true"
      ></span>
      <span class="text-bp-steel shrink-0"
        >&copy;{new Date().getFullYear()}</span
      >
      <span class="text-bp-amber shrink-0">&nbsp;&nbsp;]</span>
    </div>
  </div>
</footer>
