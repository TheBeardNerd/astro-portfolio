---
import Icon from './Icon.astro'

const skills = [
  {
    icon: 'design',
    title: 'Designing',
    text: `The way in which things are designed has been a lifelong passion. I am naturally curious, so I enjoy learning how effective design can make or break a product or idea. I believe that great design is fundamental to a brand's success.`,
  },
  {
    icon: 'code',
    title: 'Coding',
    text: `Web development is a means to realize the things about which I am passionate. Technology, problem solving, and creativity are but a few fragments which led me to realize this ambition for coding. In 2018, I began this journey, and I refuse to look back.`,
  },
  {
    icon: 'podcast',
    title: 'Podcasting',
    text: `Podcasting has become a big part of what I do. What started out as a hobby, has evolved into creating content and learning new ways to connect with listeners from around the world.`,
  },
  {
    icon: 'create',
    title: 'Creating',
    text: `I like to build things. When I'm not building things on the web, you can find me working on home projects or in my constantly evolving workshop figuring out how I can build my next thing.`,
  },
] as const
---

<section id="skills" class="text-gray-600 bg-gray-800 body-font">
  <div class="px-4 py-24 mx-auto sm:px-6 md:px-16 sm:py-32">
    {
      skills.map((skill, index) => (
        <div
          class:list={[
            'flex flex-col items-center max-w-screen-lg mx-auto lg:w-3/4 sm:flex-row',
            index !== skills.length - 1 &&
              'mb-10 pb-10 border-b border-gray-200',
          ]}
        >
          <div class="inline-flex items-center justify-center flex-shrink-0 w-20 h-20 text-teal-700 bg-white rounded sm:w-32 sm:h-32 sm:mr-10">
            <Icon type={skill.icon} class="w-5/12 h-1/2" />
          </div>
          <div class="flex-grow mt-6 text-center sm:text-left sm:mt-0">
            <h2 class="mb-2 text-2xl font-medium text-white">
              <strong>{skill.title}</strong>
            </h2>
            <p class="leading-relaxed tracking-wide text-white">{skill.text}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
