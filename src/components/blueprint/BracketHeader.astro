---
interface Props {
  title: string
  meta?: string
  class?: string
  as?: 'div' | 'h1' | 'h2' | 'h3'
}

const { title, meta = '', class: className = '', as: Tag = 'div' } = Astro.props
---

<Tag
  class:list={[
    'flex items-center gap-0 w-full font-mono text-xs tracking-widest overflow-hidden',
    className,
  ]}
>
  <span class="text-bp-amber shrink-0">[&nbsp;&nbsp;</span>
  <span class="text-bp-text text-sm uppercase shrink-0">{title}</span>
  <span
    class="bracket-line mx-3 inline-block h-px bg-bp-border shrink"
    style="min-width: 2rem; flex: 1;"
    aria-hidden="true"></span>
  {meta && <span class="text-bp-steel shrink-0 uppercase">{meta}</span>}
  <span class="text-bp-amber shrink-0">&nbsp;&nbsp;]</span>
</Tag>
