---
interface Props {
  bullets: string[]
}
const { bullets } = Astro.props
---

<ul class="mt-3 space-y-2 list-none p-0">
  {
    bullets.map((bullet) => (
      <li class="flex gap-3 font-body text-base text-bp-text opacity-75 leading-7">
        <span class="text-bp-amber shrink-0 mt-px">→</span>
        <span>{bullet}</span>
      </li>
    ))
  }
</ul>
