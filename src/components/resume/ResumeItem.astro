---
import ResumeBulletList from './ResumeBulletList.astro'
import CornerTicks from '../blueprint/CornerTicks.astro'
import type { ResumeItemData } from '../../data/resume'

interface Props {
  item: ResumeItemData
}
const { item } = Astro.props
---

<div>
  <!-- Organization header -->
  <div class="flex flex-col items-start gap-4 mb-2">
    {
      item.logo && (
        <div class="relative inline-block shrink-0">
          <div class="relative border border-bp-border p-2">
            <CornerTicks size="w-2 h-2" thin />
            {item.logo.darkSrc ? (
              <div class="p-3">
                <img
                  src={item.logo.darkSrc}
                  alt={item.logo.alt}
                  class="object-contain w-24 h-12"
                />
              </div>
            ) : (
              <div class="bg-white p-3">
                <img
                  src={item.logo.src}
                  alt={item.logo.alt}
                  class="object-contain w-24 h-12"
                />
              </div>
            )}
          </div>
        </div>
      )
    }
    <h3 class="font-display text-2xl text-bp-text">{item.organization}</h3>
  </div>

  {
    item.entries.map((entry, index) => (
      <div>
        {index > 0 && item.divideEntries && (
          <hr class="my-6 border-t border-dashed border-bp-border" />
        )}

        {(entry.role || entry.date) && (
          <div class="flex flex-wrap items-baseline gap-2 mb-2">
            {entry.role && (
              <span
                class:list={[
                  'font-mono text-sm text-bp-amber tracking-wide',
                  entry.roleClass,
                ]}
              >
                {entry.role}
              </span>
            )}
            {entry.role && entry.date && (
              <span class="font-mono text-bp-steel text-xs" aria-hidden="true">
                —
              </span>
            )}
            {entry.date && (
              <span
                class:list={[
                  'font-mono text-xs text-bp-steel tracking-widest',
                  entry.dateClass,
                ]}
              >
                {entry.date}
              </span>
            )}
          </div>
        )}

        {entry.description && (
          <p
            class:list={[
              'font-body text-base text-bp-text opacity-75 leading-7 mb-2',
              entry.descriptionClass,
            ]}
          >
            {entry.description}
          </p>
        )}

        {entry.link && (
          <a
            href={entry.link.href}
            class="font-mono text-xs text-bp-steel hover:text-bp-amber transition-colors duration-200 underline"
          >
            {entry.link.label}
          </a>
        )}

        {entry.bullets && entry.bullets.length > 0 && (
          <ResumeBulletList bullets={entry.bullets} />
        )}
      </div>
    ))
  }
</div>
