---
const labelClass = 'text-sm leading-7 text-gray-600'
const inputClass =
  'w-full px-4 py-2 text-base leading-8 text-gray-800 transition-colors duration-300 ease-in-out bg-gray-300 border-2 border-gray-300 rounded outline-none focus:border-teal-600'
const textareaClass =
  'w-full h-56 px-4 py-2 text-base leading-6 text-gray-800 transition-colors duration-300 ease-in-out bg-gray-300 border-2 border-gray-300 rounded outline-none resize-none md:h-48 focus:border-teal-600'
---

<section
  id="contact"
  class="flex items-center justify-center px-4 pt-16 pb-24 md:pt-24 md:pb-32 sm:px-6 md:px-16"
>
  <div class="w-full max-w-screen-lg lg:w-3/4">
    <h2
      class="mb-4 text-3xl font-bold leading-snug text-left text-gray-800 md:text-4xl md:mb-6"
    >
      Get in touch with me
    </h2>

    <form
      method="POST"
      name="contact"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="contact" />

      <div class="hidden">
        <label
          >Don't fill this out if you're human: <input
            name="bot-field"
            type="text"
            autocomplete="off"
            tabindex="-1"
          /></label
        >
      </div>

      <div class="flex flex-wrap -mx-2">
        <div class="w-full px-2 mb-4 md:w-1/2">
          <label for="name" class={labelClass}>Name</label>
          <input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            required
            class={inputClass}
          />
        </div>

        <div class="w-full px-2 mb-4 md:w-1/2">
          <label for="email" class={labelClass}>Email</label>
          <input
            id="email"
            name="email"
            type="email"
            inputmode="email"
            autocomplete="email"
            required
            class={inputClass}
          />
        </div>

        <div class="w-full px-2 mb-4">
          <label for="subject" class={labelClass}>Subject</label>
          <input
            id="subject"
            name="subject"
            type="text"
            autocomplete="off"
            required
            class={inputClass}
          />
        </div>

        <div class="flex flex-col w-full px-2 mb-8">
          <label for="message" class={labelClass}>Message</label>
          <textarea
            id="message"
            name="message"
            autocomplete="off"
            required
            class={textareaClass}></textarea>
        </div>
      </div>

      <div class="sm:flex sm:justify-end">
        <button
          class="w-full px-8 py-3 text-white bg-teal-700 rounded sm:w-auto"
          type="submit"
        >
          Send
        </button>
      </div>
    </form>
  </div>
</section>
