---
import BracketHeader from './blueprint/BracketHeader.astro'
import FormField from './blueprint/FormField.astro'
import { SOCIAL_LINKS } from '../config/site'
---

<section
  id="contact"
  class="px-6 py-32 md:px-12 md:py-40 border-t border-bp-border"
>
  <div class="max-w-screen-xl mx-auto">
    <BracketHeader
      as="h2"
      title="Initiate Contact"
      meta="METHOD: DIRECT  STATUS: OPEN"
      class="mb-16"
      data-animate="from-left"
    />

    <div class="max-w-2xl">
      <form
        method="POST"
        name="contact"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-6"
      >
        <input type="hidden" name="form-name" value="contact" />
        <div class="hidden">
          <label>
            Don't fill this out if you're human:
            <input
              name="bot-field"
              type="text"
              autocomplete="off"
              tabindex="-1"
            />
          </label>
        </div>

        <!-- Name + Email row -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <FormField
            id="name"
            name="name"
            label="// NAME"
            autocomplete="name"
            required
            data-animate="from-left"
            data-animate-delay="100"
          />
          <FormField
            id="email"
            name="email"
            label="// EMAIL"
            type="email"
            inputmode="email"
            autocomplete="email"
            required
            data-animate="from-left"
            data-animate-delay="200"
          />
        </div>

        <!-- Subject -->
        <FormField
          id="subject"
          name="subject"
          label="// SUBJECT"
          autocomplete="off"
          required
          data-animate="from-left"
          data-animate-delay="300"
        />

        <!-- Message -->
        <FormField
          id="message"
          name="message"
          label="// MESSAGE"
          as="textarea"
          autocomplete="off"
          required
          rows={6}
          data-animate="from-left"
          data-animate-delay="400"
        />

        <!-- Submit -->
        <div
          class="flex justify-end"
          data-animate="fade"
          data-animate-delay="500"
        >
          <button
            type="submit"
            class="btn-transmit font-display text-xl tracking-widest px-10 py-3 bg-bp-amber text-bp-bg border-2 border-bp-amber hover:text-bp-bg transition-colors duration-300"
          >
            TRANSMIT →
          </button>
        </div>
      </form>

      <!-- Alternative channels -->
      <div
        class="mt-16 pt-8 border-t border-dashed border-bp-border"
        data-animate="fade"
        data-animate-delay="600"
      >
        <div
          class="flex items-center gap-3 mb-4 font-mono text-xs tracking-widest"
        >
          <span class="text-bp-steel shrink-0">// ALTERNATIVE CHANNELS</span>
          <span class="flex-1 block h-px bg-bp-border" aria-hidden="true"
          ></span>
        </div>
        <div class="space-y-3">
          {
            SOCIAL_LINKS.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-3 font-mono text-xs tracking-widest transition-colors duration-200"
                aria-label={link.label}
              >
                <span class="shrink-0 mt-[1px] text-bp-amber transition-transform duration-150 group-hover:translate-x-1">
                  →
                </span>
                <span class="min-w-0">
                  <span class="block uppercase text-bp-text group-hover:text-bp-amber transition-colors duration-200">
                    {link.label}
                  </span>
                  <span class="block break-all text-bp-steel group-hover:text-bp-amber transition-colors duration-200">
                    {link.href
                      .replace('https://www.', '')
                      .replace('https://', '')}
                  </span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
